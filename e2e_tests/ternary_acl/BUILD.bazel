load("@rules_kotlin//kotlin:jvm.bzl", "kt_jvm_test")

genrule(
    name = "ternary_acl_pb",
    srcs = ["ternary_acl.p4"],
    outs = ["ternary_acl.txtpb"],
    cmd = "$(execpath //p4c_backend:p4c-4ward) -I $$(dirname $(execpath @p4c//:core_p4)) -o $@ $(SRCS)",
    tools = [
        "//p4c_backend:p4c-4ward",
        "@p4c//:core_p4",
        "@p4c//:p4include",
    ],
)

kt_jvm_test(
    name = "ternary_acl_test",
    srcs = ["TernaryAclTest.kt"],
    data = [
        "ternary_acl.stf",
        ":ternary_acl_pb",
        "//simulator",
    ],
    test_class = "fourward.e2e.ternaryacl.TernaryAclTest",
    deps = [
        "//e2e_tests/stf:stf_runner",
        "@maven//:com_google_protobuf_protobuf_java",
        "@maven//:junit_junit",
    ],
)
