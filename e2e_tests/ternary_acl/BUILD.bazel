load("@rules_kotlin//kotlin:jvm.bzl", "kt_jvm_test")
load("//bazel:fourward_pipeline.bzl", "fourward_pipeline")

package(
    default_applicable_licenses = ["//:license"],
    default_testonly = True,
    licenses = ["notice"],
)

fourward_pipeline(
    name = "ternary_acl_pb",
    src = "ternary_acl.p4",
    out = "ternary_acl.txtpb",
    visibility = ["//p4runtime:__pkg__"],
)

kt_jvm_test(
    name = "ternary_acl_test",
    srcs = ["TernaryAclTest.kt"],
    data = [
        "ternary_acl.stf",
        ":ternary_acl_pb",
    ],
    test_class = "fourward.e2e.ternaryacl.TernaryAclTest",
    deps = [
        "//stf",
        "@fourward_maven//:junit_junit",
    ],
)
