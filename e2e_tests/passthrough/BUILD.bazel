load("@rules_kotlin//kotlin:jvm.bzl", "kt_jvm_test")
load("//e2e_tests:p4c.bzl", "p4c_compile")

package(
    default_applicable_licenses = ["//:license"],
    default_testonly = True,
    licenses = ["notice"],
)

p4c_compile(
    name = "passthrough",
    src_p4 = "passthrough.p4",
    visibility = ["//p4runtime:__pkg__"],
)

# Runs the passthrough STF test against the 4ward simulator.
kt_jvm_test(
    name = "passthrough_test",
    srcs = ["PassthroughTest.kt"],
    data = [
        "passthrough.stf",
        ":passthrough_pb",
    ],
    test_class = "fourward.e2e.passthrough.PassthroughTest",
    deps = [
        "//stf",
        "@fourward_maven//:junit_junit",
    ],
)
