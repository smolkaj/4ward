# Both switches forward to port 1, which is linked — routing loop.
# Used to test that cross-switch P4Runtime forwarding handles loops gracefully.

switch s1 ../basic_table/basic_table.txtpb
switch s2 ../basic_table/basic_table.txtpb
link s1:1 s2:1

s1: add port_table hdr.ethernet.etherType:0x0800 forward(1)
s2: add port_table hdr.ethernet.etherType:0x0800 forward(1)
