# Same as two_switch.nstf, but with inline table entries instead of external
# STF files. Everything in one file.

switch s1 ../basic_table/basic_table.txtpb
switch s2 ../basic_table/basic_table.txtpb
link s1:1 s2:1

s1: add port_table hdr.ethernet.etherType:0x0800 forward(1)
s2: add port_table hdr.ethernet.etherType:0x0800 forward(2)

packet s1:0 FFFFFFFFFFFF 000000000001 0800 DEADBEEF
expect s2:2 FFFFFFFFFFFF 000000000001 0800 DEADBEEF
