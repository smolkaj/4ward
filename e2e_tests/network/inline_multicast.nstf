# Tests inline PRE directives (multicast group setup).
# s1 multicasts to ports 1 and 2. Port 1 is linked to s2, port 2 is edge.

switch s1 ../trace_tree/multicast.txtpb
switch s2 ../basic_table/basic_table.txtpb
link s1:1 s2:1

s1: mc_mgrp_create 1
s1: mc_node_create 0 1 2
s1: mc_node_associate 1 0
s2: add port_table hdr.ethernet.etherType:0x0800 forward(2)

packet s1:0 FFFFFFFFFFFF 000000000001 0800 DEADBEEF
expect s1:2 FFFFFFFFFFFF 000000000001 0800 DEADBEEF
expect s2:2 FFFFFFFFFFFF 000000000001 0800 DEADBEEF
