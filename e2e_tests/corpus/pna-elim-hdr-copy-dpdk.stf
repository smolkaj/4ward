# PNA header copy elimination: LPM table with next_hop/drop actions.
# Tests: PNA pipeline with header-to-header copy, send_to_port, drop.
# Direction is NET_TO_HOST by default, so tmpDir = srcAddr.

add ipv4_da_lpm ipv4_addr:10.0.0.0/8 next_hop(vport:1)

# IPv4 srcAddr=10.0.0.1 matches 10.0.0.0/8 -> port 1
packet 0 001122334455 00aabbccddee 0800 4500001400000000400600000A0000010A000002
expect 1 001122334455 00aabbccddee 0800 4500001400000000400600000A0000010A000002$

# IPv4 srcAddr=192.168.1.1 no match -> default drop
packet 0 001122334455 00aabbccddee 0800 450000140000000040060000C0A801010A000002

# Non-IPv4 -> ipv4 not valid -> table not applied -> drop
packet 0 001122334455 00aabbccddee 0806 0001080006040001
