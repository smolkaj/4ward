#       src=10.0.0.1 dst=10.0.0.2
packet 0 001122334455 00aabbccddee 0800 4500001400000000400600000A0000010A000002
expect 0 001122334455 00aabbccddee 0800 4500001400000000400600000A0000010A000002$
