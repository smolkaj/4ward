# PSA table hit/miss: applies same table 4x with hit/miss conditionals.
# Tests: table.apply().hit, table.apply().miss, setValid/setInvalid.
# No send_to_port → packets dropped by PSA default.

add tbl hdr.ethernet.srcAddr:0x00aabbccddee remove_header()

# Matching packet: tbl applied 4 times with hit → ifHit/ifMiss logic chain
packet 0 001122334455 00aabbccddee 0800

# Non-matching packet: tbl applied 4 times with miss → different logic chain
packet 0 001122334455 00ffeeddccbb 0800
