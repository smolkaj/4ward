# PSA ActionProfile: shared across tables with different action subsets.
# tbl has {NoAction, a2}, tbl2 has {NoAction, a1}.
# Tests: ActionProfile with per-table action subset restrictions.
# No send_to_port → packets dropped by PSA default.

add tbl hdr.ethernet.srcAddr:0x00aabbccddee a2(param:0x0800)
add tbl2 hdr.ethernet.srcAddr:0x00aabbccddee a1(param:0x112233445566)

packet 0 001122334455 00aabbccddee 0800
