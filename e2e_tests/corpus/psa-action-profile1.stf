# PSA ActionProfile: indirect table with parameterized actions.
# Tests: ActionProfile extern, parameterized action execution.
# No send_to_port → packets dropped by PSA default.

# Install action profile member and table entry.
# The table uses ActionProfile(1024) for indirect action specification.
add tbl hdr.ethernet.srcAddr:0x00aabbccddee a1(param:0x112233445566)

# Packet matching table entry → a1 modifies dstAddr, then dropped (no send_to_port)
packet 0 001122334455 00aabbccddee 0800

# Packet not matching → NoAction, then dropped
packet 0 001122334455 00ffeeddccbb 0800
