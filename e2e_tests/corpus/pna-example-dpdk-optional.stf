# PNA optional match: exact on dstAddr + optional on srcAddr + exact on protocol.
# Default action is drop.

# Match on dstAddr=10.0.0.2, protocol=6 (TCP), srcAddr wildcard
add ipv4_tbl hdr.ipv4.dstAddr:0x0A000002 hdr.ipv4.protocol:0x06 next_hop(vport:1)

# IPv4 TCP to 10.0.0.2 -> match -> port 1
packet 0 001122334455 00aabbccddee 0800 4500001400000000400600000A0000010A000002
expect 1 001122334455 00aabbccddee 0800 4500001400000000400600000A0000010A000002$

# IPv4 UDP (proto=17) to 10.0.0.2 -> no match on protocol -> drop
packet 0 001122334455 00aabbccddee 0800 4500001400000000401100000A0000010A000002

# Non-IPv4 -> drop
packet 0 001122334455 00aabbccddee 0806 0001080006040001
