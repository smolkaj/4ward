# PSA Counter: packet counter at fixed index.
# Tests: Counter extern instantiation and count().
# No send_to_port → packets dropped by PSA default.

add tbl hdr.ethernet.srcAddr:0x00aabbccddee execute()

# Table hit → execute action increments counter at index 1024
packet 0 001122334455 00aabbccddee 0800

# Second packet → counter incremented again
packet 0 001122334455 00aabbccddee 0800
