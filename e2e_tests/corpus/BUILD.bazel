# Tests blocked on pkt.lookahead() / packet.advance() support. These fail at
# p4c compile time with "functions or methods returning structures are not
# supported on this target" or similar target errors.
# Run manually: bazel test //e2e_tests/corpus:lookahead_stf_corpus_test
corpus_test_suite(
    name = "lookahead_stf_corpus_test",
    tags = ["manual"],
    tests = [
        "checksum-l4-bmv2",
        "checksum1-bmv2",
        "issue1025-bmv2",
        "issue1755-1-bmv2",
        "issue1755-bmv2",
        "issue1768-bmv2",
    ],
)

# Tests blocked on header stack operations (field access, push/pop, copy).
# These fail with "field access on non-aggregate value: HeaderStackVal".
corpus_test_suite(
    name = "header_stack_stf_corpus_test",
    tags = ["manual"],
    tests = [
        "array-copy-bmv2",
    ],
)

# Tests blocked on various unclassified missing features.
corpus_test_suite(
    name = "other_stf_corpus_test",
    tags = ["manual"],
    tests = [
        "bvec-hdr-bmv2",
        "checksum2-bmv2",
        "checksum3-bmv2",
        "equality-bmv2",
    ],
)
