load("@rules_kotlin//kotlin:jvm.bzl", "kt_jvm_library")
load("//e2e_tests:p4testgen.bzl", "p4_testgen_test")

kt_jvm_library(
    name = "p4testgen_test_class",
    srcs = ["P4TestgenTest.kt"],
    visibility = ["//e2e_tests:__subpackages__"],
    deps = [
        "//e2e_tests/stf:stf_runner",
        "@maven//:junit_junit",
