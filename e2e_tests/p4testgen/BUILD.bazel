load("@rules_kotlin//kotlin:jvm.bzl", "kt_jvm_library")
load("//e2e_tests:p4testgen.bzl", "p4_testgen_test")

kt_jvm_library(
    name = "p4testgen_test_class",
    srcs = ["P4TestgenTest.kt"],
    visibility = ["//e2e_tests:__subpackages__"],
    deps = [
        "//e2e_tests/stf:stf_runner",
        "@maven//:junit_junit",
    ],
)

# p4testgen-generated STF tests. Each entry runs p4testgen (symbolic execution
# + Z3) on a P4 program from the p4c test corpus to generate test cases, then
# runs them against the simulator.
#
# Tests that expose simulator bugs are tagged "manual" so they don't fail
# `bazel test //...`.

# --- Passing tests (all paths) ---

p4_testgen_test(
    name = "flag_lost-bmv2",
    src_p4 = "@p4c//testdata/p4_16_samples:flag_lost-bmv2.p4",
)

