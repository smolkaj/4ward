)

# p4testgen-generated STF tests. Each entry runs p4testgen (symbolic execution
# + Z3) on a P4 program from the p4c test corpus to generate test cases, then
# runs them against the simulator.

_ARITH_SKELETON = ["@p4c//testdata/p4_16_samples:arith-skeleton.p4"]

_ARITH_INLINE_SKELETON = ["@p4c//testdata/p4_16_samples:arith-inline-skeleton.p4"]

