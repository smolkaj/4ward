# SAI P4 (middleblock instantiation) — vendored from sonic-net/sonic-pins.
# Used for E2E testing of the P4Runtime server with @p4runtime_translation.

exports_files(
    glob([
        "fixed/*.p4",
        "fixed/*.h",
        "instantiations/google/*.p4",
        "instantiations/google/*.h",
    ]),
    visibility = ["//e2e_tests:__subpackages__"],
)

filegroup(
    name = "sai_p4_srcs",
    srcs = glob([
        "fixed/*.p4",
        "fixed/*.h",
        "instantiations/google/*.p4",
        "instantiations/google/*.h",
    ]),
    visibility = ["//e2e_tests:__subpackages__"],
)

# Forked v1model with port_id_t (newtype + @p4runtime_translation) on
# standard_metadata port fields. Generated by patching stock v1model.p4.
genrule(
    name = "v1model_sai",
    srcs = [
        "fixed/v1model_sai.patch",
        "@p4c//p4include:v1model.p4",
    ],
    outs = ["fixed/v1model_sai.p4"],
    cmd = "cp $(execpath @p4c//p4include:v1model.p4) $@ && patch -p1 $@ $(execpath fixed/v1model_sai.patch)",
)

genrule(
    name = "sai_middleblock_pb",
    srcs = [
        "instantiations/google/middleblock.p4",
        ":sai_p4_srcs",
        ":v1model_sai",
    ],
    outs = ["sai_middleblock.txtpb"],
    cmd = " ".join([
        "$(execpath //p4c_backend:p4c-4ward)",
        "-I $$(dirname $(execpath @p4c//p4include:core.p4))",
        "-I $$(dirname $(execpath :v1model_sai))",
        "-o $@",
        "$(execpath instantiations/google/middleblock.p4)",
    ]),
    tools = [
        "//p4c_backend:p4c-4ward",
        "@p4c//p4include",
        "@p4c//p4include:core.p4",
    ],
    visibility = ["//p4runtime:__pkg__"],
)
