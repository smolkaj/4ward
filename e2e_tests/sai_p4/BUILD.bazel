load("//bazel:fourward_pipeline.bzl", "fourward_pipeline")

package(
    default_applicable_licenses = ["//:license"],
    default_testonly = True,
    licenses = ["notice"],
)

# SAI P4 (middleblock instantiation) — vendored from sonic-net/sonic-pins.
# Used for E2E testing of the P4Runtime server with @p4runtime_translation.

exports_files(
    glob([
        "fixed/*.p4",
        "fixed/*.h",
        "instantiations/google/*.p4",
        "instantiations/google/*.h",
    ]),
    visibility = ["//e2e_tests:__subpackages__"],
)

filegroup(
    name = "sai_p4_srcs",
    srcs = glob([
        "fixed/*.p4",
        "fixed/*.h",
        "instantiations/google/*.p4",
        "instantiations/google/*.h",
    ]),
    visibility = ["//e2e_tests:__subpackages__"],
)

fourward_pipeline(
    name = "sai_middleblock",
    src = "instantiations/google/middleblock.p4",
    out = "sai_middleblock.txtpb",
    extra_srcs = [":sai_p4_srcs"],
    visibility = ["//p4runtime:__pkg__"],
)

# BMv2 JSON (for head-to-head benchmarking against the 4ward simulator).
genrule(
    name = "sai_middleblock_bmv2_json",
    srcs = [
        "instantiations/google/middleblock.p4",
        ":sai_p4_srcs",
    ],
    outs = ["sai_middleblock.json"],
    cmd = " ".join([
        "$(execpath @p4c//:p4c_bmv2)",
        "-I $$(dirname $(execpath @p4c//p4include:core.p4))",
        "-DPLATFORM_BMV2",
        "-o $@",
        "$(execpath instantiations/google/middleblock.p4)",
    ]),
    tools = [
        "@p4c//:p4c_bmv2",
        "@p4c//p4include",
        "@p4c//p4include:core.p4",
    ],
    visibility = ["//e2e_tests/bmv2_diff:__pkg__"],
)

# 4ward PipelineConfig with BMv2 defines (for P4Info used by BMv2 benchmark).
fourward_pipeline(
    name = "sai_middleblock_bmv2",
    src = "instantiations/google/middleblock.p4",
    out = "sai_middleblock_bmv2.txtpb",
    defines = ["PLATFORM_BMV2"],
    extra_srcs = [":sai_p4_srcs"],
    visibility = ["//e2e_tests/bmv2_diff:__pkg__"],
)

# Binary ForwardingPipelineConfig (for use as a pre-built artifact).
fourward_pipeline(
    name = "sai_middleblock_binpb",
    src = "instantiations/google/middleblock.p4",
    out = "sai_middleblock.binpb",
    extra_srcs = [":sai_p4_srcs"],
    out_format = "p4runtime",
    visibility = ["//visibility:public"],
)
