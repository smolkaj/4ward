# Expected trace tree for action_selector_miss: zero-fork tree on miss.
# The selector table misses, so the default action (drop) runs directly
# with no forking.
events {
  parser_transition {
    parser_name: "MyParser"
    from_state: "start"
    to_state: "accept"
  }
}
events {
  table_lookup {
    table_name: "ecmp"
    hit: false
    action_name: "drop"
  }
}
events {
  action_execution {
    action_name: "drop"
  }
}
