# Expected trace tree for action_selector_miss: zero-fork tree on miss.
# The selector table misses, so the default action (NoAction) runs directly
# with no forking. The P4 source declares drop() as default, but p4c compiles
# const_default_action_id to NoAction when the table has an implementation.
events {
  parser_transition {
    parser_name: "MyParser"
    from_state: "start"
    to_state: "accept"
  }
}
events {
  table_lookup {
    table_name: "ecmp"
    hit: false
    action_name: "NoAction"
  }
}
events {
  action_execution {
    action_name: "NoAction"
  }
}
