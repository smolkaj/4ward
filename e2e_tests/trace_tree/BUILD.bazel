load("@rules_kotlin//kotlin:jvm.bzl", "kt_jvm_test")
load("//e2e_tests:p4c.bzl", "p4c_compile")

package(default_testonly = True)

# P4/STF files used by bmv2_diff tests (cross-package reference).
exports_files([
    "action_selector_3.p4",
    "action_selector_3.stf",
    "selector_exit.p4",
    "selector_exit.stf",
])

# =============================================================================
# Trace tree golden tests (Track 3)
#
# Each test compiles a P4 program, sends a packet, and compares the resulting
# TraceTree against a golden .txtpb file.  Passing tests run in CI; tests for
# unimplemented features are tagged "manual".
# =============================================================================

_GOLDEN = [
    "no_fork",
    "action_selector_3",
    "action_selector_miss",
    "action_selector_nested",
    "clone_and_multicast",
    "clone_ingress_egress",
    "clone_preserve_meta",
    "clone_last_wins",
    "clone_plus_selector",
    "clone_with_egress",
    "multicast",
    "multicast_drop_replica",
    "multicast_selector",
    "selector_exit",
]

# Programs without golden files — tested via STF expect directives only.
_STF_ONLY = [
    "selector_multi_packet",
    "selector_post_fork_table",
]

_P4_PROGRAMS = _GOLDEN + _STF_ONLY

_PASSING = _GOLDEN

_MANUAL = []

[p4c_compile(
    name,
    "%s.p4" % name,
) for name in _P4_PROGRAMS if name not in ("clone_with_egress", "action_selector_3", "multicast")]

p4c_compile(
    name = "multicast",
    src_p4 = "multicast.p4",
    visibility = [
        "//cli:__pkg__",
        "//e2e_tests/network:__pkg__",
    ],
)

# Compiled separately so p4runtime conformance tests can use them as data deps.
p4c_compile(
    name = "clone_with_egress",
    src_p4 = "clone_with_egress.p4",
    visibility = ["//p4runtime:__pkg__"],
)

p4c_compile(
    name = "action_selector_3",
    src_p4 = "action_selector_3.p4",
    visibility = ["//p4runtime:__pkg__"],
)

_TEST_DEPS = [
    "//e2e_tests:golden_file",
    "//stf",
    "//simulator:ir_java_proto",
    "//simulator:p4runtime_java_proto",
    "//simulator:simulator_java_proto",
    "//simulator:simulator_lib",
    "@fourward_maven//:com_google_protobuf_protobuf_java",
    "@fourward_maven//:junit_junit",
]

kt_jvm_test(
    name = "golden_trace_tree_test",
    srcs = ["GoldenTraceTreeTest.kt"],
    data = ["%s.stf" % n for n in _PASSING] +
           ["%s.golden.txtpb" % n for n in _PASSING] +
           [":%s_pb" % n for n in _PASSING],
    test_class = "fourward.e2e.tracetree.GoldenTraceTreeTest",
    deps = _TEST_DEPS,
)

kt_jvm_test(
    name = "trace_tree_consistency_test",
    srcs = ["TraceTreeConsistencyTest.kt"],
    data = ["%s.stf" % n for n in _P4_PROGRAMS] +
           [":%s_pb" % n for n in _P4_PROGRAMS],
    test_class = "fourward.e2e.tracetree.TraceTreeConsistencyTest",
    deps = _TEST_DEPS,
)

kt_jvm_test(
    name = "golden_trace_tree_test_manual",
    srcs = ["GoldenTraceTreeTest.kt"],
    data = ["%s.stf" % n for n in _MANUAL] +
           ["%s.golden.txtpb" % n for n in _MANUAL] +
           [":%s_pb" % n for n in _MANUAL],
    tags = ["manual"],
    test_class = "fourward.e2e.tracetree.GoldenTraceTreeTest",
    deps = _TEST_DEPS,
)
