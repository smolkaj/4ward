# Strict-deps fixes for grpc_kotlin under rules_kotlin 2.x.
#
# 1. compiler/.../generator declares the common `kotlinx-coroutines-
#    core` Maven artifact, but strict-deps traces its symbols to
#    `kotlinx-coroutines-core-jvm`.
#
# 2. `kt_jvm_grpc_library` generates a kt_jvm_library whose source
#    uses `io.grpc.*`, `kotlinx.coroutines.*`, and the user's own
#    java_proto classes — none of them declared directly; they leak
#    through the hardcoded `:stub`/`:context` deps. Extend the
#    macro's `kt_deps` to declare all three.
#
# TODO: drop the generator hunk once grpc/grpc-kotlin#756 lands and
# a new release ships. The macro hunk is more opinionated and may
# need a separate upstream conversation.
diff --git a/compiler/src/main/java/io/grpc/kotlin/generator/BUILD.bazel b/compiler/src/main/java/io/grpc/kotlin/generator/BUILD.bazel
--- a/compiler/src/main/java/io/grpc/kotlin/generator/BUILD.bazel
+++ b/compiler/src/main/java/io/grpc/kotlin/generator/BUILD.bazel
@@ -17,7 +17,7 @@ kt_jvm_library(
         "@grpc-java//core",
         "@grpc_kotlin_maven//:com_google_guava_guava",
         "@grpc_kotlin_maven//:com_squareup_kotlinpoet",
-        "@grpc_kotlin_maven//:org_jetbrains_kotlinx_kotlinx_coroutines_core",
+        "@grpc_kotlin_maven//:org_jetbrains_kotlinx_kotlinx_coroutines_core_jvm",
         "@protobuf//:protobuf_java",
     ],
 )
diff --git a/kt_jvm_grpc.bzl b/kt_jvm_grpc.bzl
--- a/kt_jvm_grpc.bzl
+++ b/kt_jvm_grpc.bzl
@@ -123,6 +123,13 @@ def kt_jvm_grpc_library(
     kt_deps.extend([
         "@grpc_kotlin//stub/src/main/java/io/grpc/kotlin:stub",
         "@grpc_kotlin//stub/src/main/java/io/grpc/kotlin:context",
+        # Resolved at load time against grpc_kotlin's own repo mapping so
+        # external callers (whose repo doesn't see grpc_kotlin_maven) work.
+        Label("@grpc-java//api"),
+        Label("@grpc_kotlin_maven//:org_jetbrains_kotlinx_kotlinx_coroutines_core_jvm"),
+        # Forward the user's java_proto into the generated kt_jvm_library
+        # so strict-deps recognizes it as a direct dep, not transitive.
+        deps[0],
     ])

     kt_grpc_label = ":%s_DO_NOT_DEPEND_kt_grpc" % name
