+bazel_dep(name = "boost.filesystem", version = "1.90.0.bcr.1")
+bazel_dep(name = "boost.functional", version = "1.90.0.bcr.1")
+bazel_dep(name = "boost.multiprecision", version = "1.90.0.bcr.1")
+bazel_dep(name = "boost.program_options", version = "1.90.0.bcr.1")
+bazel_dep(name = "boost.thread", version = "1.90.0.bcr.1")
+bazel_dep(name = "boost.variant", version = "1.90.0.bcr.1")
diff --color -ruN a/include/bm/bm_sim/dynamic_bitset.h b/include/bm/bm_sim/dynamic_bitset.h
--- a/include/bm/bm_sim/dynamic_bitset.h	2026-03-06 06:52:00
+++ b/include/bm/bm_sim/dynamic_bitset.h	2026-03-06 06:52:16
@@ -48,6 +48,16 @@
       find_lowest_bit<uint32_t>(sw);
 }
 
+// On arm64 macOS, unsigned long is 64-bit but distinct from uint64_t
+// (unsigned long long). DynamicBitset::Block is unsigned long, so we need
+// this specialization to avoid linker errors.
+#if defined(__APPLE__) && defined(__aarch64__)
+template<>
+inline int find_lowest_bit<unsigned long>(unsigned long v) {
+  return find_lowest_bit<uint64_t>(static_cast<uint64_t>(v));
+}
+#endif
+
 class DynamicBitset {
  public:
   using Block = unsigned long;  // NOLINT(runtime/int)
