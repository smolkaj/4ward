_http_file(
    name = "dokka_analysis",
    downloaded_file_path = "analysis-kotlin-descriptors.jar",
    sha256 = "829788c40891a2a3c4b9435cb9ec80d645560d926e9fbbd08ccc29e8e4f1eb7c",
    url = "https://repo1.maven.org/maven2/org/jetbrains/dokka/analysis-kotlin-descriptors/2.0.0/analysis-kotlin-descriptors-2.0.0.jar",
)

_http_file(
    name = "dokka_kotlinx_html",
    downloaded_file_path = "kotlinx-html-jvm.jar",
    sha256 = "b68f39cd9ad7b46de0a0e77e7f5908d4e7661f3d0c85d2d9171543fcd5b156fb",
    url = "https://repo1.maven.org/maven2/org/jetbrains/kotlinx/kotlinx-html-jvm/0.9.1/kotlinx-html-jvm-0.9.1.jar",
)

_http_file(
    name = "dokka_freemarker",
    downloaded_file_path = "freemarker.jar",
    sha256 = "04d65ec1bde6cea20e3495d5e78ef96ab774d9936434861d3254bd88e7e94f92",
    url = "https://repo1.maven.org/maven2/org/freemarker/freemarker/2.3.32/freemarker-2.3.32.jar",
)
