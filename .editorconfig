root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{kt,kts}]
indent_style = space
indent_size = 2

[*.{cpp,h,cc}]
indent_style = space
indent_size = 2

[*.proto]
indent_style = space
indent_size = 2

[*.{py,bzl}]
indent_style = space
indent_size = 4

[BUILD.bazel]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
