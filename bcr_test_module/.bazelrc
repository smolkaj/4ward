# `bcr_test_module/` is a distinct Bazel workspace, so it does NOT
# inherit the root `.bazelrc`. These are the minimum build flags
# needed for `bazel build @fourward//...` to work from here. They
# mirror the inline `FLAGS=()` block in the `bcr-consumer-check` job
# in `../.github/workflows/ci.yml` — keep the two in sync.

common --enable_bzlmod
common --noenable_workspace

build --cxxopt=-std=c++20
build --host_cxxopt=-std=c++20

# Hermetic JDK so local builds don't depend on whatever system Java
# happens to be installed (same rationale as the root `.bazelrc`).
build --java_runtime_version=remotejdk_21
build --tool_java_runtime_version=remotejdk_21
